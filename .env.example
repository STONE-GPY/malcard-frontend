# Use mock API client (cards + analysis) for offline development.
# Set to 'false' to call the real backend.
VITE_USE_MOCK_API=true

# Backend base URL (used when VITE_USE_MOCK_API=false)
VITE_API_BASE_URL=http://localhost:8000

# Show the in-app developer panel (mock toggle + scenario picker) in DEV
# builds. Off by default. Set to 'true' to enable. Production builds never
# render the panel regardless of this flag.
# VITE_SHOW_DEV_PANEL=true
