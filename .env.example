# Use mock API client (cards + analysis) for offline development.
# Set to 'false' to call the real backend.
VITE_USE_MOCK_API=true

# Backend base URL. LEAVE UNSET for normal dev: the app then calls the same
# origin it is served from and the Vite dev server proxies the backend
# (/analysis, /tts, ...) to localhost:8000. That single-origin setup is what
# makes LAN (phone) and the Cloudflare tunnel work -- hard-coding
# http://localhost:8000 makes a phone call its own localhost and is blocked as
# mixed content over the https tunnel. Only set this to point at a SEPARATELY
# DEPLOYED backend (use its full https URL).
# VITE_API_BASE_URL=https://api.example.com

# Show the in-app developer panel (mock toggle + scenario picker) in DEV
# builds. Off by default. Set to 'true' to enable. Production builds never
# render the panel regardless of this flag.
# VITE_SHOW_DEV_PANEL=true
